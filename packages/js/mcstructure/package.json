{
  "name": "@taku128/mcstructure",
  "version": "0.1.0",
  "description": "Convert Bedrock .mcstructure files to Java Structure NBT. Browser- and Node-compatible (no LevelDB required).",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "@taku128/core": "workspace:*",
    "prismarine-nbt": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0"
  },
  "license": "MIT",
  "author": "Taku128",
  "repository": {
    "type": "git",
    "url": "https://github.com/Taku128/mc-nbt-converter.git",
    "directory": "packages/js/mcstructure"
  },
  "homepage": "https://github.com/Taku128/mc-nbt-converter#readme"
}
