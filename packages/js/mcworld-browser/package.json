{
  "name": "@taku128/mcworld-browser",
  "version": "0.1.4",
  "description": "Convert Bedrock .mcworld (LevelDB zip) to Java Structure NBT in the browser. Pure JS — no native LevelDB binding.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "test": "node --test test/*.test.mjs",
    "demo": "vite --config demo/vite.config.ts",
    "demo:build": "vite build --config demo/vite.config.ts"
  },
  "dependencies": {
    "@taku128/core": "workspace:*",
    "fflate": "^0.8.2"
  },
  "devDependencies": {
    "@taku128/mcworld": "workspace:^",
    "@types/node": "^20.0.0",
    "adm-zip": "^0.5.10",
    "deepslate": "^0.25.1",
    "gl-matrix": "^3.4.4",
    "leveldb-zlib": "^1.2.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vite": "^8.0.10"
  },
  "license": "MIT",
  "author": "Taku128",
  "repository": {
    "type": "git",
    "url": "https://github.com/Taku128/mc-nbt-converter.git",
    "directory": "packages/js/mcworld-browser"
  },
  "homepage": "https://github.com/Taku128/mc-nbt-converter#readme"
}
